<!-- Card -->
<div class="relative bg-white rounded-xl shadow-[0_12px_32px_rgba(75,36,9,0.06)] border border-gray-100 overflow-hidden">
    <!-- Borda superior gradiente -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-roster-orange-light to-roster-orange-lighter"></div>

    <form class="p-8 pt-10 space-y-5" action="/login" method="POST" novalidate>
    <!-- Email -->
    <div>
        <label for="user_email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
        <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-600 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <path d="m3 7 9 6 9-6"/>
            </svg>
        </span>
        <input
            id="user_email"
            name="user[email]"
            type="email"
            autocomplete="email"
            placeholder="nome@empresa.com"
            class="w-full h-11 pl-10 pr-3 rounded-lg border border-gray-300 bg-white text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-roster-orange-light focus:ring-2 focus:ring-roster-orange-light/20 transition"
        />
        </div>
    </div>

    <!-- Senha -->
    <div>
        <div class="flex items-center justify-between mb-2">
        <label for="user_password" class="block text-sm font-medium text-gray-700">Senha</label>
        <a href="#" class="text-sm font-medium text-roster-orange-light hover:text-roster-orange transition">Esqueceu a senha?</a>
        </div>
        <div class="relative">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-600 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="11" width="16" height="10" rx="2"/>
            <path d="M8 11V7a4 4 0 1 1 8 0v4"/>
            </svg>
        </span>
        <input
            id="user_password"
            name="user[password]"
            type="password"
            autocomplete="current-password"
            placeholder="••••••••"
            class="w-full h-11 pl-10 pr-10 rounded-lg border border-gray-300 bg-white text-sm text-gray-900 placeholder-gray-400 tracking-widest focus:outline-none focus:border-roster-orange-light focus:ring-2 focus:ring-roster-orange-light/20 transition"
        />
        <button
            type="button"
            id="togglePassword"
            aria-label="Mostrar ou ocultar senha"
            class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-600 hover:text-gray-800 transition"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/>
            <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/>
            <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/>
            <line x1="2" y1="2" x2="22" y2="22"/>
            </svg>
        </button>
        </div>
    </div>

    <!-- Botão Entrar -->
    <button
        type="submit"
        class="w-full h-12 rounded-full bg-roster-orange-light hover:bg-roster-orange text-white text-sm font-semibold flex items-center justify-center gap-2 transition shadow-sm"
    >
        <span>Entrar</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
        </svg>
    </button>
    </form>
</div>

<!-- Footer -->
<p class="text-center text-sm text-gray-500 mt-6">
    Não tem uma conta?
    <a href="#" class="font-medium text-roster-orange-light hover:text-roster-orange transition">Cadastre-se</a>
</p>